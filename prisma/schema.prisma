generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  DIRECTEUR_PROD
  CHARGE_DE_PROD
  COMPTABLE
  STAGIAIRE
}

// Rôle d'un user dans un workspace (Phase 2 multi-user N-N, ticket suite #69).
// V1 : un seul rôle MEMBER (tous les membres ont les mêmes droits, qui peuvent
// inviter/révoquer). V2 : on ajoutera ADMIN, VIEWER, etc. selon besoin.
enum MembershipRole {
  MEMBER
}

enum LigneTag {
  ARTISTE        // Remplace COMEDIEN + DROIT — CS Comédiens appliquée
  TECHNICIEN_HCS // CS Techniciens appliquée
  STUDIO         // Pas de CS
  MUSIQUE        // Pas de CS
  AGENT          // Commission agent voix off (10% des lignes Artistes sélectionnées)
}

enum DevisStatut {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

enum FactureType {
  ACOMPTE
  SOLDE
  AVOIR
}

enum FactureStatut {
  BROUILLON
  EMISE
  PAYEE_PARTIEL
  PAYEE
  EN_RETARD
  ANNULEE
}

enum CounterType {
  DEVIS
  FACTURE
  BDC
}

enum RelanceType {
  ENVOI           // Premier envoi de la facture
  RELANCE_1       // Première relance (J+15)
  RELANCE_2       // Deuxième relance (J+30)
  MISE_EN_DEMEURE // Mise en demeure (J+45)
}

// ─────────────────────────────────────────────
// COMPANY (Tenant)
// ─────────────────────────────────────────────

model Company {
  id           String @id @default(cuid())
  name         String
  siret        String @unique
  tvaIntra     String
  address      String
  city         String @default("")
  postalCode   String @default("")
  email        String @default("")
  phone        String @default("")
  iban         String
  bic          String
  nomBanque    String  @default("")
  logoUrl      String?
  primaryColor String @default("#3B82F6")

  // Taux par défaut (surchargeables par devis ou par client)
  defaultTauxFg         Float @default(0.05)
  defaultTauxMarge      Float @default(0.15)
  defaultTauxCsComedien Float @default(0.57)
  defaultTauxCsTech     Float @default(0.65)

  // Conditions de paiement par défaut (mention L441-9)
  conditionsPaiement String @default("Paiement à 30 jours. Pénalités de retard : 15% par an exigibles à 45 jours. Indemnité forfaitaire de recouvrement : 40 €.")

  // Préfixes de numérotation appliqués lors de la génération (ex : "DEV-2026-",
  // "FAC-2026-"). Le Counter stocke le numéro seul ; le format final est
  // `${prefixDevis}${counter.value}` côté getNextDevisNumero.
  prefixDevis   String @default("")
  prefixFacture String @default("")

  // Sections custom proposées en plus des 5 par défaut (Voix-Off, Studio,
  // Musique, Droits, Autres) lors de la création d'un devis.
  // Format : [{ nom: string, categorie: "ARTISTE"|"TECHNICIEN_HCS"|"STUDIO"|"MUSIQUE"|"AUTRE" }]
  // JSON plutôt que table dédiée car liste statique et rarement lue.
  customSections Json @default("[]")

  clerkOrgId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users       User[]
  memberships Membership[]
  invitations Invitation[]
  clients     Client[]
  devis       Devis[]
  factures    Facture[]
  counters    Counter[]
  auditLogs   AuditLog[]
  templates   DevisTemplate[]
  documents  Document[]
  budgets    BudgetPrevisionnel[]
  agents     Agent[]
  comediens  Comedien[]
  relances   Relance[]
  // Phase 1 multi-tenant : scope direct sur les 5 tables liées
  sections     DevisSection[]
  lignes       DevisLigne[]
  bdcs         BDC[]
  paiements    Paiement[]
  budgetLignes BudgetLigne[]
}

// ─────────────────────────────────────────────
// DOCUMENT (pièces jointes PDF réutilisables)
// ─────────────────────────────────────────────

model Document {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  url       String
  createdAt DateTime @default(now())

  @@index([companyId])
}

// ─────────────────────────────────────────────
// USER (synced from Clerk webhook)
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  name      String
  role      Role     @default(STAGIAIRE)
  // Company "par défaut" / historique du user. Conservé pour rétrocompat
  // pendant la transition Phase 2 — l'authz multi-workspace passe par la
  // table Membership ci-dessous. Sera supprimé en Phase 3 (V3).
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templates DevisTemplate[]

  // Phase 2 multi-user N-N (suite #69).
  memberships         Membership[] @relation("UserMemberships")
  invitedMemberships  Membership[] @relation("InvitedByMemberships")
  invitationsSent     Invitation[] @relation("InvitationsSent")
}

// Invitation à rejoindre une Company. Phase 2 multi-user (suite #69).
//
// Cycle de vie :
//   - created : token genere, mail envoye, acceptedAt/revokedAt null
//   - accepted: acceptedAt set, on cree la Membership liee
//   - revoked : revokedAt set (annulation par un membre)
//   - expired : expiresAt passe (createdAt + 7j typiquement)
//
// Le token est aleatoire (UUID v4), porte dans le lien d'acceptation.
// Une invitation est UTILISABLE si acceptedAt IS NULL AND revokedAt IS NULL
// AND expiresAt > NOW.
model Invitation {
  id              String   @id @default(cuid())
  email           String
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedByUserId String
  invitedBy       User     @relation("InvitationsSent", fields: [invitedByUserId], references: [id])

  // Token aleatoire UUID v4, utilise dans le lien d'acceptation. Unique
  // globalement (pas seulement par company) pour eviter toute ambiguite
  // au moment du clic mail.
  token     String   @unique
  expiresAt DateTime

  // Cycle de vie (mutuellement exclusifs en pratique)
  acceptedAt DateTime?
  revokedAt  DateTime?

  // Si acceptedAt set, on conserve l'id de la Membership creee pour audit
  // et pour pouvoir lier les deux dans l'UI "historique des invitations".
  acceptedMembershipId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([email])
}

// Lien N-N entre User et Company (Phase 2). Source de vérité pour l'authz
// multi-workspace dans ProdBill. Cohabite avec User.companyId pendant la
// transition (fallback rétrocompat dans requireAuth()).
//
// Cycle de vie :
//   - invitedAt : DateTime de l'invitation (NOW à la création)
//   - joinedAt  : DateTime d'acceptation (NULL tant que pas accepté)
//   - revokedAt : DateTime de révocation (soft-delete)
//
// Une Membership est ACTIVE si revokedAt IS NULL AND joinedAt IS NOT NULL.
// Voir src/lib/auth/can-access-company.ts.
model Membership {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  role MembershipRole @default(MEMBER)

  // Qui a invité ce membre. NULL pour les Memberships créées par le backfill
  // des utilisateurs historiques (ils n'ont pas été invités, ils étaient là
  // avant) ou pour le créateur original d'un workspace.
  invitedByUserId String?
  invitedBy       User?   @relation("InvitedByMemberships", fields: [invitedByUserId], references: [id])

  invitedAt DateTime  @default(now())
  joinedAt  DateTime?
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// CLIENT
// ─────────────────────────────────────────────

model Client {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name       String
  siret      String?
  tvaIntra   String?
  address    String
  city       String  @default("")
  postalCode String  @default("")
  email      String
  phone      String?

  // Tarification spéciale client (override des taux société)
  tauxFgOverride    Float?
  tauxMargeOverride Float?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devis        Devis[]
  factures     Facture[]
  budgetLignes BudgetLigne[]

  @@index([companyId])
}

// ─────────────────────────────────────────────
// DEVIS
// ─────────────────────────────────────────────

model Devis {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id])

  numero      String?     // "25-0042" — généré à l'envoi (null en brouillon)
  objet       String
  description String?
  statut      DevisStatut @default(BROUILLON)

  // Taux appliqués pour ce devis
  tauxCsComedien Float
  tauxCsTech     Float
  tauxFg         Float
  tauxMarge      Float

  // Totaux calculés et dénormalisés (recalculés à chaque sauvegarde)
  sousTotal        Float @default(0)
  csComedien       Float @default(0)
  csTechniciens    Float @default(0)
  baseMarge        Float @default(0)
  fraisGeneraux    Float @default(0)
  marge            Float @default(0)
  totalHt          Float @default(0)
  remise           Float @default(0) // Remise exceptionnelle (montant déductible)
  coproduction     Float @default(0) // Apport en industrie (montant déductible)
  totalApresRemise Float @default(0)
  tauxTva          Float @default(20) // Taux TVA appliqué (%) — 20, 10, 5.5, 0…
  // Mention légale custom affichée sur le PDF UNIQUEMENT si tauxTva = 0.
  // Défaut côté UI : "Art. 293 B du CGI" (franchise en base). Modifiable
  // par l'utilisateur (étranger UE = "Art. 196 directive 2006/112/CE",
  // hors UE = "Art. 262 ter du CGI", etc.). NULL si TVA appliquée.
  tvaMention       String?
  tva              Float @default(0)
  totalTtc         Float @default(0)

  dateEmission DateTime?
  dateValidite DateTime?
  dateSeance   DateTime?
  notes        String?
  pdfUrl       String?   // Vercel Blob URL

  // BDC reçu DU client (scan/PDF). Distinct du modèle BDC (sortant,
  // auto-généré pour le client) et du champ Facture.numeroBdc
  // (référence texte). Ticket #79.
  bdcClientUrl        String?
  bdcClientFilename   String?
  bdcClientUploadedAt DateTime?

  // Période d'exploitation des droits cédés au client (ticket #69).
  // Globale au devis en V1 — peut être affinée par ligne en V2 si besoin.
  // Règles : si Fin saisie, Début doit l'être aussi (et inversement).
  // Libellé sans dates = "à définir" autorisé. Tout null = pas de droits
  // (ex: prestation technique seule).
  periodeExploitationDebut    DateTime?
  periodeExploitationFin      DateTime?
  periodeExploitationLibelle  String?

  // Champs d'identification projet (libres, optionnels)
  nomProjet      String?
  refDevis       String? // Numéro de devis client (ex: DEV-2024-001)
  annee          Int?    // Année du projet

  // Suivi budgétaire
  tauxPipe Int? // Probabilité de closing 0-100%

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  sections  DevisSection[]
  factures  Facture[]
  bdc       BDC?
  auditLogs AuditLog[]

  @@index([companyId])
  @@index([clientId])
}

// ─────────────────────────────────────────────
// DEVIS SECTION
// ─────────────────────────────────────────────

model DevisSection {
  id      String @id @default(cuid())
  devisId String
  devis   Devis  @relation(fields: [devisId], references: [id], onDelete: Cascade)

  // Phase 1 multi-tenant : companyId direct (en plus du scope indirect via devisId)
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  titre String
  ordre Int

  lignes DevisLigne[]

  @@index([devisId])
  @@index([companyId])
}

// ─────────────────────────────────────────────
// DEVIS LIGNE
// ─────────────────────────────────────────────

model DevisLigne {
  id        String       @id @default(cuid())
  sectionId String
  section   DevisSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  // Phase 1 multi-tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  libelle        String
  tag            LigneTag
  quantite       Float    @default(1)
  prixUnit       Float
  total          Float    // quantite × prixUnit (dénormalisé)
  tauxIndexation Float      @default(0) // pourcentage, ex: 2.0 pour 2%
  comedienId     String?  // Comédien associé (ARTISTE uniquement, interne)
  comedien       Comedien? @relation(fields: [comedienId], references: [id])
  agentId        String?  // Agent voix-off direct (ARTISTE uniquement, interne)
  agent          Agent?   @relation(fields: [agentId], references: [id])
  paiementComedien Boolean @default(false) // statut paiement interne, jamais dans PDF
  // Si true : la ligne (et son indexation) est exclue du baseMarge utilisé
  // pour calculer Frais Généraux et Marge. Les charges sociales sur la ligne
  // restent dues, et la ligne reste dans le sousTotal HT.
  // Cas d'usage : lignes Musique (composition, droits) que Vanda ne veut pas
  // surfacturer via Marge/FG. Indépendant du tag : peut s'appliquer à
  // n'importe quel tag (ARTISTE, MUSIQUE, STUDIO, etc.).
  horsMarge      Boolean    @default(false)
  ordre          Int

  @@index([sectionId])
  @@index([companyId])
}

// ─────────────────────────────────────────────
// FACTURE
// ─────────────────────────────────────────────

model Facture {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id])
  devisId   String?
  devis     Devis?  @relation(fields: [devisId], references: [id])

  numero String // "25-0042-A1", "25-0042-S1", "AV-25-0042" — unicité scopée par tenant
  type   FactureType
  statut FactureStatut @default(BROUILLON)

  // Montants
  totalHt  Float
  tauxTva  Float @default(20) // Taux TVA appliqué (%) — 20, 10, 5.5, 0… (snapshot)
  // Snapshot de la mention TVA custom du devis source, affichée sur le PDF
  // facture uniquement si tauxTva = 0. NULL si TVA appliquée.
  tvaMention String?
  tva      Float
  totalTtc Float

  // Décomposition snapshot (au moment de l'émission ou de l'import) — permet
  // de reproduire sur la facture le même bloc récapitulatif que le devis.
  // Pour un ACOMPTE 50 %, ces valeurs sont ramenées au prorata.
  // TODO immuabilité légale : aujourd'hui la facture lit les lignes
  // depuis le devis source. Une modif post-émission du devis altère
  // la facture, ce qui viole l'art. 289 CGI. À traiter avant prod :
  // soit dupliquer les lignes en FactureSection/FactureLigne au moment
  // de l'émission, soit verrouiller le devis dès qu'il a une facture.
  sousTotal      Float @default(0)
  csComedien     Float @default(0)
  csTechniciens  Float @default(0)
  baseMarge      Float @default(0)
  fraisGeneraux  Float @default(0)
  marge          Float @default(0)
  remise         Float @default(0) // Remise exceptionnelle (déductible, prorata)
  coproduction   Float @default(0) // Apport en industrie (déductible, prorata)
  tauxCsComedien Float @default(0)
  tauxCsTech     Float @default(0)
  tauxFg         Float @default(0)
  tauxMarge      Float @default(0)

  // Dates
  dateEmission   DateTime?
  dateEcheance   DateTime?
  datePaiement   DateTime?
  dateReglement  DateTime?

  // Mentions légales L441-9 (snapshot au moment de l'émission)
  siretEmetteur      String @default("")
  tvaIntraEmetteur   String @default("")
  ibanEmetteur       String @default("")
  bicEmetteur        String @default("")
  nomBanqueEmetteur  String @default("")
  conditionsPaiement String @default("")
  nomEmetteur        String @default("")
  adresseEmetteur    String @default("")

  // Référence commande client
  numeroBdc  String?

  // Période d'exploitation — snapshot recopié depuis le devis source
  // au moment de l'émission (re-snapshot à chaque facture acompte/solde).
  // Immuabilité après EMISE comme le reste de la facture. Ticket #69.
  periodeExploitationDebut    DateTime?
  periodeExploitationFin      DateTime?
  periodeExploitationLibelle  String?

  // Stockage
  pdfUrl     String? // Vercel Blob
  facturxUrl String? // XML ZUGFeRD

  // Immuabilité légale : une fois EMISE, aucune modification autorisée
  emiseAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  paiements Paiement[]
  relances  Relance[]
  auditLogs AuditLog[]

  @@unique([companyId, numero])
  @@index([companyId])
  @@index([clientId])
  @@index([devisId])
}

// ─────────────────────────────────────────────
// RELANCE EMAIL
// ─────────────────────────────────────────────

model Relance {
  id          String      @id @default(cuid())
  factureId   String
  facture     Facture     @relation(fields: [factureId], references: [id], onDelete: Cascade)
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  type        RelanceType
  sentAt      DateTime    @default(now())
  sentTo      String      // email destinataire
  subject     String
  createdById String

  @@index([factureId])
  @@index([companyId])
}

// ─────────────────────────────────────────────
// BON DE COMMANDE
// ─────────────────────────────────────────────

model BDC {
  id      String @id @default(cuid())
  devisId String @unique
  devis   Devis  @relation(fields: [devisId], references: [id])

  // Phase 1 multi-tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  numero    String   // "BDC-25-0042" — unicité scopée par tenant (cf. @@unique)
  pdfUrl    String?
  createdAt DateTime @default(now())

  @@unique([companyId, numero])
  @@index([companyId])
}

// ─────────────────────────────────────────────
// PAIEMENT / LETTRAGE
// ─────────────────────────────────────────────

model Paiement {
  id        String  @id @default(cuid())
  factureId String
  facture   Facture @relation(fields: [factureId], references: [id])

  // Phase 1 multi-tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  montant   Float
  date      DateTime
  reference String?  // Référence bancaire
  mode      String?  // Virement, chèque, CB…
  notes     String?

  createdAt DateTime @default(now())

  @@index([factureId])
  @@index([companyId])
}

// ─────────────────────────────────────────────
// COUNTER — numérotation séquentielle par année
// ─────────────────────────────────────────────

model Counter {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id])
  year      Int
  type      CounterType
  value     Int         @default(0)

  @@unique([companyId, year, type])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String  @id @default(cuid())
  companyId  String
  company    Company @relation(fields: [companyId], references: [id])
  userId     String
  userName   String  @default("")
  action     String  // "DEVIS_CREE", "FACTURE_EMISE", "CLIENT_MODIFIE"…
  entityType String  // "Devis", "Facture", "Client"…
  entityId   String
  details    Json?

  devisId   String?
  devis     Devis?   @relation(fields: [devisId], references: [id])
  factureId String?
  facture   Facture? @relation(fields: [factureId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([entityType, entityId])
}

// ─────────────────────────────────────────────
// DEVIS TEMPLATE
// ─────────────────────────────────────────────

model DevisTemplate {
  id             String   @id @default(cuid())
  companyId      String
  userId         String
  name           String
  description    String?
  // JSON : TemplateSection[] = { titre, lignes: { libelle, tag, quantite, ordre }[] }[]
  sections       Json
  tauxCsComedien Float
  tauxCsTech     Float
  tauxFg         Float
  tauxMarge      Float
  isShared       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// COMEDIEN
// ─────────────────────────────────────────────

model Comedien {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  prenom    String
  nom       String
  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lignes DevisLigne[]

  @@index([companyId])
  @@index([agentId])
}

// ─────────────────────────────────────────────
// AGENT VOIX OFF
// ─────────────────────────────────────────────

model Agent {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nom            String
  prenom         String?
  email          String?
  telephone      String?
  agence         String?  // Nom de l'agence
  tauxCommission Float    @default(10) // En %
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lignes    DevisLigne[]
  comediens Comedien[]

  @@index([companyId])
}

// ─────────────────────────────────────────────
// BUDGET PREVISIONNEL
// ─────────────────────────────────────────────

model BudgetPrevisionnel {
  id        String        @id @default(cuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  annee     Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  lignes    BudgetLigne[]

  @@unique([companyId, annee])
  @@index([companyId])
}

model BudgetLigne {
  id                  String             @id @default(cuid())
  budgetId            String
  budget              BudgetPrevisionnel @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  clientId            String
  client              Client             @relation(fields: [clientId], references: [id])

  // Phase 1 multi-tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  libelle             String
  nomCommercial       String?
  montantPrevisionnel Float
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([budgetId])
  @@index([companyId])
}
